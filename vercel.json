{
  "builds": [
    { "src": "backend/package.json", "use": "@vercel/next" },
    { "src": "frontend/package.json", "use": "@vercel/next" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/api/$1" },
    { "src": "/admin/(.*)", "dest": "/backend/admin/$1" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
